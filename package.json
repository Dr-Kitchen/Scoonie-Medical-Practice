{
  "name": "scoonie-medical-practice",
  "version": "1.0.0",
  "description": "Scoonie Medical Practice website",
  "scripts": {
    "build": "npx tailwindcss -i src/assets/css/main.css -o _site/assets/css/main.css --minify && npx @11ty/eleventy",
    "serve": "npx @11ty/eleventy --serve",
    "dev": "concurrently \"npx tailwindcss -i src/assets/css/main.css -o _site/assets/css/main.css --watch\" \"npx @11ty/eleventy --serve\""
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-navigation": "^0.3.5",
    "concurrently": "^8.2.2",
    "tailwindcss": "^3.4.0"
  }
}
