---
layout: layouts/page.njk
title: Self-referral services
intro: "You can refer yourself directly to many NHS and community services — no appointment with us needed first."
description: "Self-refer directly to NHS physiotherapy, mental health, sexual health, and other services in Fife without a GP referral."
breadcrumb:
  - label: Get Help
    url: /get-help/
  - label: Self-referral services
---

<div class="prose-content max-w-3xl mb-8">
  <p>Many NHS services in Fife allow you to refer yourself directly, without needing a GP appointment first. This is often faster and just as effective — and it frees up GP appointments for people who need them.</p>
</div>

{% set categories = [
  { "id": "physical", "label": "Physical health", "icon": "physio" },
  { "id": "mental",   "label": "Mental health and wellbeing", "icon": "mental" },
  { "id": "sexual",   "label": "Sexual and reproductive health", "icon": "sexual" },
  { "id": "children", "label": "Children and families", "icon": "children" },
  { "id": "travel",   "label": "Travel and vaccinations", "icon": "travel" },
  { "id": "other",    "label": "Other services", "icon": "other" }
] %}

{# Quick jump links #}
<nav aria-label="Service categories" class="mb-10 bg-neutral-warm rounded-lg p-5">
  <p class="font-semibold text-neutral-dark mb-3 text-sm">Jump to a category:</p>
  <div class="flex flex-wrap gap-2">
    {% for cat in categories %}
      {% set hasServices = false %}
      {% for service in collections.services %}
        {% if service.data.category == cat.id %}{% set hasServices = true %}{% endif %}
      {% endfor %}
      {% if hasServices %}
      <a href="#cat-{{ cat.id }}" class="inline-block px-3 py-1.5 text-sm font-medium bg-white border border-gray-200 rounded-full hover:border-brand-primary hover:bg-brand-light transition-colors no-underline text-neutral-dark">
        {{ cat.label }}
      </a>
      {% endif %}
    {% endfor %}
  </div>
</nav>

{% for cat in categories %}
  {% set catServices = [] %}
  {% for service in collections.services %}
    {% if service.data.category == cat.id %}
      {% set catServices = (catServices.push(service), catServices) %}
    {% endif %}
  {% endfor %}

  {% if catServices.length > 0 %}
  <section aria-labelledby="cat-{{ cat.id }}" class="mb-12">
    <h2 id="cat-{{ cat.id }}" class="text-xl font-bold text-neutral-dark mb-5 border-b-2 border-brand-primary pb-2 inline-block">{{ cat.label }}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {% for service in catServices %}
      <div class="service-card hover:border-brand-primary hover:shadow-md transition-all">
        <h3 class="service-card__title text-base mb-2">{{ service.data.title }}</h3>
        <div class="service-card__desc mb-3">{{ service.templateContent | safe }}</div>

        {% if service.data.booking_note %}
        <p class="text-sm mt-2 bg-brand-light rounded px-3 py-2">
          <strong class="text-brand-primary">How to access:</strong> {{ service.data.booking_note }}
        </p>
        {% endif %}

        <div class="flex flex-wrap gap-x-4 gap-y-2 mt-3">
          {% if service.data.phone %}
          <a href="tel:{{ service.data.phone | replace(' ', '') }}" class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-primary no-underline hover:underline">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            {{ service.data.phone }}
          </a>
          {% endif %}

          {% if service.data.second_phone %}
          <a href="tel:{{ service.data.second_phone | replace(' ', '') }}" class="inline-flex items-center gap-1.5 text-sm text-brand-primary no-underline hover:underline">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            {% if service.data.second_phone_label %}<span class="text-neutral-mid">{{ service.data.second_phone_label }}:</span> {% endif %}{{ service.data.second_phone }}
          </a>
          {% endif %}

          {% if service.data.email %}
          <a href="mailto:{{ service.data.email }}" class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-primary no-underline hover:underline">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            {{ service.data.email }}
          </a>
          {% endif %}

          {% if service.data.website %}
          <a href="{{ service.data.website }}" class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-primary no-underline hover:underline" rel="noopener noreferrer" target="_blank">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
            Visit website
          </a>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}
{% endfor %}

<div class="mt-4 prose-content max-w-3xl">
  <p class="text-sm text-neutral-mid">Can't find what you need? <a href="/contact/get-in-touch/">Contact us</a> and we'll help you find the right service.</p>
</div>
