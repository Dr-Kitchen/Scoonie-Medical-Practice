<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#005eb8">

  <title>{% if title %}{{ title }} | {% endif %}{{ site.name }}</title>
  <meta name="description" content="{{ description if description else 'Scoonie Medical Practice — NHS GP surgery serving Leven and the Levenmouth area of Fife, Scotland.' }}">

  <!-- Open Graph -->
  <meta property="og:title" content="{% if title %}{{ title }} | {% endif %}{{ site.name }}">
  <meta property="og:description" content="{{ description if description else 'Scoonie Medical Practice — NHS GP surgery serving Leven and the Levenmouth area of Fife, Scotland.' }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:site_name" content="{{ site.name }}">

  <!-- Schema.org MedicalClinic -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "MedicalClinic",
    "name": "{{ site.name }}",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "{{ site.address.line1 }}, {{ site.address.line2 }}",
      "addressLocality": "{{ site.address.town }}",
      "postalCode": "{{ site.address.postcode }}",
      "addressCountry": "GB"
    },
    "telephone": "{{ site.phone }}",
    "email": "{{ site.email }}",
    "url": "{{ site.url }}",
    "openingHours": ["Mo-Fr 08:00-18:00"]
  }
  </script>

  <link rel="stylesheet" href="/assets/css/main.css">
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>

  {% include "partials/skip-nav.njk" %}
  {% include "partials/alert-banner.njk" %}
  {% include "partials/nav.njk" %}

  <main id="main-content" tabindex="-1">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  <script src="/assets/js/main.js" defer></script>
</body>
</html>
