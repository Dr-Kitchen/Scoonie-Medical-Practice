<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#2a4698">

  <title>{% if title %}{{ title }} | {% endif %}{{ site.name }}</title>
  <meta name="description" content="{{ description if description else 'Scoonie Medical Practice — NHS GP surgery serving Leven and the Levenmouth area of Fife, Scotland.' }}">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon-32x32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/apple-touch-icon.png">

  <!-- Open Graph -->
  <meta property="og:title" content="{% if title %}{{ title }} | {% endif %}{{ site.name }}">
  <meta property="og:description" content="{{ description if description else 'Scoonie Medical Practice — NHS GP surgery serving Leven and the Levenmouth area of Fife, Scotland.' }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:image" content="{{ site.url }}/assets/images/og-image.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  {# Schema.org MedicalClinic — openingHours built from CMS-managed site.openingHours #}
  {% set dayAbbr = { "Monday": "Mo", "Tuesday": "Tu", "Wednesday": "We", "Thursday": "Th", "Friday": "Fr", "Saturday": "Sa", "Sunday": "Su" } %}
  {% set schemaHours = [] %}
  {% for row in site.openingHours %}
    {% if row.open and row.close %}
      {% set schemaHours = (schemaHours.push(dayAbbr[row.day] + " " + row.open + "-" + row.close), schemaHours) %}
    {% endif %}
  {% endfor %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "MedicalClinic",
    "name": "{{ site.name }}",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "{{ site.address.line1 }}, {{ site.address.line2 }}",
      "addressLocality": "{{ site.address.town }}",
      "postalCode": "{{ site.address.postcode }}",
      "addressCountry": "GB"
    },
    "telephone": "{{ site.phone }}",
    "email": "{{ site.email }}",
    "url": "{{ site.url }}",
    "openingHours": {{ schemaHours | dump | safe }}
  }
  </script>

  <link rel="stylesheet" href="/assets/css/main.css">

  <!--
    Netlify Identity widget — loaded only when an identity token is present in
    the URL (password reset, invite, email confirmation links). This keeps the
    widget out of every normal page load while allowing the admin auth flow to
    work correctly.
  -->
  <script>
    (function () {
      var h = window.location.hash;
      if (h && /[#&](invite_token|recovery_token|confirmation_token)=/.test(h)) {
        var s = document.createElement('script');
        s.src = 'https://identity.netlify.com/v1/netlify-identity-widget.js';
        document.head.appendChild(s);
      }
    })();
  </script>
</head>
<body>

  {% include "partials/skip-nav.njk" %}
  <div class="brand-bar" aria-hidden="true"></div>
  {% include "partials/nav.njk" %}
  {% include "partials/alert-banner.njk" %}

  <main id="main-content" tabindex="-1">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  {# Mobile floating call button — visible on small screens only #}
  <a
    href="tel:{{ site.phone | replace(' ', '') }}"
    class="mobile-call-btn lg:hidden"
    aria-label="Call {{ site.phone }}"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
    </svg>
  </a>

  {# Cookie consent banner #}
  <div id="cookie-consent" class="cookie-consent is-hidden" role="region" aria-label="Cookie consent">
    <div class="cookie-consent__inner">
      <p class="cookie-consent__text">
        This website uses essential cookies to remember your preferences (such as dismissed alerts). We do not use tracking or advertising cookies.
        <a href="/contact/data-protection/" class="text-white underline">Learn more</a>
      </p>
      <div class="cookie-consent__actions">
        <button id="cookie-accept" class="btn btn--primary text-sm" style="min-height:40px;padding:0.5rem 1.25rem;">Accept</button>
      </div>
    </div>
  </div>

  {# Site data for client-side JS (open/closed indicator) #}
  <script>
    window.__SITE_DATA__ = {
      openingHours: {{ site.openingHours | dump | safe }},
      plannedClosures: {{ site.plannedClosures | dump | safe }},
      phone: "{{ site.phone }}"
    };
  </script>
  <script src="/assets/js/main.js" defer></script>
</body>
</html>
