{% macro actionCard(icon, title, description, url, ctaLabel) %}
<a href="{{ url }}" class="action-card" aria-label="{{ title }}">
  <div class="action-card__icon" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" class="w-10 h-10">
      <path stroke-linecap="round" stroke-linejoin="round" d="{{ icon }}"/>
    </svg>
  </div>
  <h3 class="action-card__title">{{ title }}</h3>
  <p class="action-card__desc">{{ description }}</p>
  <span class="action-card__cta">{{ ctaLabel }} →</span>
</a>
{% endmacro %}
