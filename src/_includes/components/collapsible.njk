{% macro collapsible(id, label, content) %}
<div class="mb-2">
  <button
    data-collapsible
    aria-expanded="false"
    aria-controls="collapsible-{{ id }}"
    class="collapsible__button"
  >
    <span>{{ label }}</span>
    <svg class="collapsible__icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </button>
  <div id="collapsible-{{ id }}" class="collapsible__content">
    {{ content | safe }}
  </div>
</div>
{% endmacro %}
