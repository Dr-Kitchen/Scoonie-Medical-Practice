<header class="site-header" role="banner">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">

      <!-- Logo / Practice name -->
      <a href="/" class="flex items-center gap-2 no-underline" aria-label="{{ site.name }} - Home">
        <img src="/assets/images/logo-nav.svg" alt="{{ site.name }}" class="h-10 w-auto">
      </a>

      <!-- Desktop phone number + open/closed indicator -->
      <div class="hidden lg:flex items-center gap-3">
        <span id="open-closed-indicator" class="status-indicator" aria-live="polite"></span>
        <a href="tel:{{ site.phone | replace(' ', '') }}" class="flex items-center gap-1 text-sm font-semibold text-brand-primary hover:text-brand-dark no-underline" aria-label="Call us on {{ site.phone }}">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
          </svg>
          {{ site.phone }}
        </a>
      </div>

      <!-- Desktop navigation -->
      <nav aria-label="Main navigation" class="hidden lg:flex items-center gap-1">
        {% for item in navigation %}
          {% if item.children %}
            <div class="relative group">
              <button
                class="nav-link flex items-center gap-1"
                aria-expanded="false"
                aria-haspopup="true"
              >
                {{ item.label }}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="absolute top-full left-0 w-56 bg-white border border-gray-200 rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all z-50 py-1">
                <a href="{{ item.url }}" class="block px-4 py-2 text-sm font-semibold text-brand-primary hover:bg-brand-light border-b border-gray-100">
                  {{ item.label }} overview
                </a>
                {% for child in item.children %}
                <a href="{{ child.url }}" class="block px-4 py-2 text-sm text-neutral-dark hover:bg-brand-light hover:text-brand-primary">
                  {{ child.label }}
                </a>
                {% endfor %}
              </div>
            </div>
          {% else %}
            <a href="{{ item.url }}" class="nav-link {% if page.url == item.url %}nav-link--active{% endif %}">
              {{ item.label }}
            </a>
          {% endif %}
        {% endfor %}
      </nav>

      <!-- Mobile menu button -->
      <button
        data-menu-toggle
        class="lg:hidden flex items-center justify-center w-11 h-11 rounded text-neutral-dark hover:bg-gray-100"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Open navigation menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <nav
      id="mobile-menu"
      data-mobile-menu
      class="hidden lg:hidden border-t border-gray-200 pb-4"
      aria-label="Mobile navigation"
    >
      {% for item in navigation %}
        {% if item.children %}
          <div>
            <button
              data-submenu-toggle
              aria-expanded="false"
              aria-controls="submenu-{{ loop.index }}"
              class="flex items-center justify-between w-full px-0 py-3 font-medium text-neutral-dark border-b border-gray-100"
            >
              {{ item.label }}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div id="submenu-{{ loop.index }}" class="hidden pl-4">
              <a href="{{ item.url }}" class="block py-2 text-sm text-brand-primary font-medium border-b border-gray-50">
                {{ item.label }} overview
              </a>
              {% for child in item.children %}
              <a href="{{ child.url }}" class="block py-2 text-sm text-neutral-dark hover:text-brand-primary">
                {{ child.label }}
              </a>
              {% endfor %}
            </div>
          </div>
        {% else %}
          <a href="{{ item.url }}" class="block py-3 font-medium text-neutral-dark border-b border-gray-100 hover:text-brand-primary">
            {{ item.label }}
          </a>
        {% endif %}
      {% endfor %}
    </nav>
  </div>
</header>
