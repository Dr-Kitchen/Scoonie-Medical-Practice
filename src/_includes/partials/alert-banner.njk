{% set activeAlerts = collections.alerts | activeAlerts %}
{% for alertItem in activeAlerts %}
<div
  class="alert-banner alert-banner--{{ alertItem.data.severity | default('info') }}"
  role="alert"
  data-alert-banner="{{ alertItem.data.title | slug }}"
>
  <div class="max-w-6xl mx-auto px-4 flex items-start justify-between gap-4">
    <div class="flex items-start gap-2">
      {% if alertItem.data.severity === 'urgent' %}
      <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
      </svg>
      {% endif %}
      <div>
        {% if alertItem.data.title %}<strong>{{ alertItem.data.title }}</strong> — {% endif %}
        {{ alertItem.content | safe }}
      </div>
    </div>
    <button
      data-alert-dismiss="{{ alertItem.data.title | slug }}"
      class="flex-shrink-0 text-white opacity-75 hover:opacity-100 transition-opacity p-1"
      aria-label="Dismiss this alert"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
</div>
{% endfor %}
