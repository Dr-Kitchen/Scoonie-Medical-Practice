<section aria-labelledby="ctac-heading" class="mb-10">
  <h2 id="ctac-heading" class="text-xl font-bold text-neutral-dark mb-2">Treatment Room — CTAC</h2>
  <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-4 text-sm">
    <strong>Booking note:</strong> Treatment room and phlebotomy appointments are provided by NHS Fife CTAC staff and are booked via <strong>NHS Fife Reception at Leven Health Centre</strong> — not via Scoonie Medical Practice reception.
  </div>
  <p class="text-sm text-neutral-mid mb-4">CTAC nurses provide wound care, ear irrigation, B12 injections, suture removal, blood tests, and other treatment room procedures.</p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {% for member in team %}
    {% if member.category == "ctac" %}
    <div class="bg-white border border-gray-200 border-l-4 border-l-slate-500 rounded-lg p-4">
      <p class="font-semibold text-neutral-dark">{{ member.name }}</p>
      <p class="text-sm text-slate-600 mt-0.5">{{ member.role }}</p>
      {% if member.qualifications %}
      <p class="text-xs text-neutral-mid mt-2 leading-relaxed">{{ member.qualifications }}</p>
      {% endif %}
    </div>
    {% endif %}
    {% endfor %}
  </div>
</section>

<section aria-labelledby="other-heading" class="mb-10">
  <h2 id="other-heading" class="text-xl font-bold text-neutral-dark mb-4">Other attached services</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div class="bg-white border border-gray-200 border-l-4 border-l-brand-primary rounded-lg p-4">
      <p class="font-semibold text-neutral-dark">First Contact Physiotherapist</p>
      <p class="text-sm text-brand-primary mt-0.5">Physiotherapy</p>
      <p class="text-xs text-neutral-mid mt-2 leading-relaxed">For musculoskeletal problems — joint pain, back pain, sports injuries, and more. No GP referral required. Book directly via Scoonie Reception on <a href="tel:{{ site.phone | replace(' ', '') }}">{{ site.phone }}</a>.</p>
    </div>
    <div class="bg-white border border-gray-200 border-l-4 border-l-brand-primary rounded-lg p-4">
      <p class="font-semibold text-neutral-dark">District Nursing Team</p>
      <p class="text-sm text-brand-primary mt-0.5">Community Nursing</p>
      <p class="text-xs text-neutral-mid mt-2 leading-relaxed">Visit housebound patients at home for wound care, medication, and nursing support. Contact: <a href="tel:01333425656">01333 425656</a> during working hours.</p>
    </div>
    <div class="bg-white border border-gray-200 border-l-4 border-l-brand-primary rounded-lg p-4">
      <p class="font-semibold text-neutral-dark">Health Visiting Team</p>
      <p class="text-sm text-brand-primary mt-0.5">Child and Family Health</p>
      <p class="text-xs text-neutral-mid mt-2 leading-relaxed">Attached to the practice, working with families and children under five to support health, development, and wellbeing.</p>
    </div>
  </div>
</section>

