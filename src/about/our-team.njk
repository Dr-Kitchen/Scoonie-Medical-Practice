  <p class="text-sm text-neutral-mid mb-4">Our mental health nurses see patients aged 18 and over. You can book directly without a GP referral — contact Scoonie Reception on <a href="tel:{{ site.phone | replace(' ', '') }}">{{ site.phone }}</a>.</p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {% for member in team %}
