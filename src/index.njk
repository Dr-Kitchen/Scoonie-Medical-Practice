---
layout: layouts/home.njk
title: Home
description: "Scoonie Medical Practice — NHS GP surgery at Leven Health Centre, Leven, Fife. Book appointments, order prescriptions, and find health services."
---

{# ── HERO ──────────────────────────────────────────────────────────────────── #}
<section class="hero" aria-label="Practice information">
  <div class="max-w-6xl mx-auto px-4">
    <h1 class="hero__practice-name">Scoonie Medical Practice</h1>
    <p class="hero__address">{{ site.address.line1 }}, {{ site.address.line2 }}, {{ site.address.town }}</p>
    <p class="hero__phone">
      <a href="tel:{{ site.phone | replace(' ', '') }}" class="text-white no-underline hover:underline">
        <svg xmlns="http://www.w3.org/2000/svg" class="inline w-6 h-6 mr-1 -mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
        </svg>
        {{ site.phone }}
      </a>
    </p>
    <p class="hero__welcome">
      We're an NHS GP practice serving Leven and the Levenmouth area.
      We're here to help you get the care you need, as quickly and easily as possible.
      As a <a href="/about/students-and-training/" class="text-white underline hover:text-gray-200">training practice</a>, we also help develop the next generation of GPs.
    </p>
  </div>
</section>

{# ── CARE NAVIGATOR ───────────────────────────────────────────────────────── #}
<section class="py-10 px-4 bg-brand-light" aria-labelledby="care-nav-heading">
  <div class="max-w-3xl mx-auto">
    <h2 id="care-nav-heading" class="text-xl font-bold text-neutral-dark mb-2">Not sure where to start?</h2>
    <p class="text-neutral-mid mb-6">Answer a quick question and we'll point you to the right service.</p>
    <div id="care-navigator" aria-label="Care navigator tool"></div>
    <p class="text-xs text-neutral-mid mt-4">This is for guidance only. If in doubt, call us on <a href="tel:{{ site.phone | replace(' ', '') }}">{{ site.phone }}</a> or NHS 24 on <a href="tel:111">111</a>.</p>
  </div>
</section>

{# ── QUICK ACTIONS ─────────────────────────────────────────────────────────── #}
<section class="py-10 px-4 bg-white" aria-labelledby="quick-actions-heading">
  <div class="max-w-6xl mx-auto">
    <h2 id="quick-actions-heading" class="text-xl font-bold text-neutral-dark mb-6">What do you need today?</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4">

      <a href="/get-help/book-appointment/" class="action-card">
        <div class="action-card__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
          </svg>
        </div>
        <h3 class="action-card__title">Book an appointment</h3>
        <p class="action-card__desc">See a GP, nurse, or other clinician. Phone or online options available.</p>
        <span class="action-card__cta">Book now →</span>
      </a>

      <a href="/prescriptions/order-repeat/" class="action-card">
        <div class="action-card__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
          </svg>
        </div>
        <h3 class="action-card__title">Order a prescription</h3>
        <p class="action-card__desc">Request your repeat medication online, by email, or via your pharmacy.</p>
        <span class="action-card__cta">Order now →</span>
      </a>

      <a href="/new-patients/register/" class="action-card">
        <div class="action-card__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM4 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 0110.374 21c-2.331 0-4.512-.645-6.374-1.766z"/>
          </svg>
        </div>
        <h3 class="action-card__title">Register with us</h3>
        <p class="action-card__desc">New to the area? Register as a patient with Scoonie Medical Practice.</p>
        <span class="action-card__cta">Register →</span>
      </a>

      <a href="/get-help/urgent-care/" class="action-card border-red-200 hover:border-alert-urgent">
        <div class="action-card__icon text-alert-urgent" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
          </svg>
        </div>
        <h3 class="action-card__title">Urgent help</h3>
        <p class="action-card__desc">For urgent medical advice when we're closed, or if you're unsure who to call.</p>
        <span class="action-card__cta text-alert-urgent">Get urgent help →</span>
      </a>

      <a href="/contact/get-in-touch/" class="action-card">
        <div class="action-card__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
          </svg>
        </div>
        <h3 class="action-card__title">Contact us</h3>
        <p class="action-card__desc">Get in touch by phone or email. We're open Monday to Friday, 8am–6pm.</p>
        <span class="action-card__cta">Contact us →</span>
      </a>

    </div>
  </div>
</section>

{# ── NEWS TEASER ───────────────────────────────────────────────────────────── #}
{% set latestNews = collections.news %}
{% if latestNews.length %}
<section class="news-teaser" aria-labelledby="news-heading">
  <div class="max-w-6xl mx-auto">
    <h2 id="news-heading" class="text-xl font-bold text-neutral-dark mb-4">Latest from the practice</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      {% for post in latestNews | head(2) %}
      <div class="news-teaser__item">
        <p class="text-xs text-neutral-mid mb-1">{{ post.date | readableDate }}</p>
        <h3 class="text-base font-semibold text-neutral-dark mb-1">
          <a href="{{ post.url }}" class="hover:text-brand-primary no-underline text-neutral-dark">{{ post.data.title }}</a>
        </h3>
        {% if post.data.summary %}
        <p class="text-sm text-neutral-mid leading-relaxed">{{ post.data.summary }}</p>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    <a href="/about/news/" class="text-brand-primary text-sm font-medium">See all news →</a>
  </div>
</section>
{% endif %}

{# ── CAMPAIGNS ─────────────────────────────────────────────────────────────── #}
{% set activeCampaigns = collections.campaigns %}
{% if activeCampaigns and activeCampaigns.length %}
<section class="py-8 px-4 bg-white" aria-labelledby="campaigns-heading">
  <div class="max-w-6xl mx-auto">
    <h2 id="campaigns-heading" class="text-xl font-bold text-neutral-dark mb-4">Health campaigns</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {% for campaign in activeCampaigns %}
      <div class="campaign-card">
        <h3 class="font-semibold text-neutral-dark mb-1">{{ campaign.data.title }}</h3>
        <p class="text-sm text-neutral-mid mb-3">{{ campaign.content | safe }}</p>
        {% if campaign.data.link_url %}
        <a href="{{ campaign.data.link_url }}" class="text-brand-primary text-sm font-medium">{{ campaign.data.link_text | default('Find out more') }} →</a>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ── OPENING HOURS ─────────────────────────────────────────────────────────── #}
<section class="py-8 px-4 bg-neutral-warm" aria-labelledby="hours-heading">
  <div class="max-w-6xl mx-auto">
    <div class="max-w-md">
      <h2 id="hours-heading" class="text-xl font-bold text-neutral-dark mb-4">Opening hours</h2>

      <div class="mb-2">
        <button
          data-collapsible
          aria-expanded="false"
          aria-controls="opening-hours-detail"
          class="collapsible__button"
        >
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Monday – Friday: 08:00 – 18:00
          </span>
          <svg class="collapsible__icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div id="opening-hours-detail" class="collapsible__content">
          <table class="hours-table w-full" aria-label="Surgery opening hours">
            <caption class="sr-only">Opening hours for Scoonie Medical Practice</caption>
            <thead class="sr-only">
              <tr><th scope="col">Day</th><th scope="col">Hours</th></tr>
            </thead>
            <tbody>
              {% for row in site.openingHours %}
              <tr data-day="{{ row.day }}">
                <td class="font-medium w-1/2 py-2 px-3 border-b border-gray-100">{{ row.day }}</td>
                <td class="py-2 px-3 border-b border-gray-100">
                  {% if row.open %}{{ row.open }} – {{ row.close }}{% else %}<span class="text-neutral-mid">Closed</span>{% endif %}
                </td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
          <p class="text-sm text-neutral-mid mt-3 px-3 pb-2">Telephone lines open from 08:00. We are closed on public holidays.</p>
        </div>
      </div>

      <p class="text-sm text-neutral-mid mt-3">
        <strong>Out of hours?</strong> Call
        <a href="tel:111" class="text-brand-primary font-semibold">NHS 24 on 111</a>
        for urgent medical advice.
      </p>
    </div>
  </div>
</section>

{# ── NOT SURE WHAT YOU NEED — SIGNPOSTING ─────────────────────────────────── #}
<section class="signpost-section" aria-labelledby="signpost-heading">
  <div class="max-w-6xl mx-auto">
    <h2 id="signpost-heading" class="text-xl font-bold text-neutral-dark mb-2">Helpful resources</h2>
    <p class="text-neutral-mid mb-6 max-w-2xl">Many conditions can be treated without a GP appointment. These services might be faster and easier for you.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

      <div class="service-card">
        <h3 class="service-card__title">Pharmacy First</h3>
        <p class="service-card__desc">Your local pharmacy can treat many common conditions — including UTIs, ear infections, sinusitis, and more — without a GP appointment. Free on the NHS.</p>
        <a href="/get-help/pharmacy-first/" class="text-brand-primary text-sm font-medium mt-3 inline-block">Find out more →</a>
      </div>

      <div class="service-card">
        <h3 class="service-card__title">Self-referral services</h3>
        <p class="service-card__desc">You can refer yourself directly to many NHS services — including physiotherapy, mental health support, and more — without needing to see us first.</p>
        <a href="/get-help/self-referral/" class="text-brand-primary text-sm font-medium mt-3 inline-block">See all services →</a>
      </div>

      <div class="service-card">
        <h3 class="service-card__title">NHS Inform</h3>
        <p class="service-card__desc">Scotland's national health information service has advice on hundreds of conditions, symptoms, and treatments. A great first stop if you're unsure.</p>
        <a href="https://www.nhsinform.scot/" rel="noopener noreferrer" class="text-brand-primary text-sm font-medium mt-3 inline-block">Visit NHS Inform →</a>
      </div>

    </div>

    <div class="mt-6 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
      <a href="https://www.nhsinform.scot/illnesses-and-conditions/" rel="noopener noreferrer" class="text-sm bg-white border border-gray-200 rounded p-3 text-center text-neutral-dark hover:border-brand-primary hover:text-brand-primary no-underline transition-colors">Health A-Z</a>
      <a href="https://www.nhsinform.scot/healthy-living/" rel="noopener noreferrer" class="text-sm bg-white border border-gray-200 rounded p-3 text-center text-neutral-dark hover:border-brand-primary hover:text-brand-primary no-underline transition-colors">Healthy living</a>
      <a href="https://www.nhsinform.scot/care-support-and-rights/mental-health/" rel="noopener noreferrer" class="text-sm bg-white border border-gray-200 rounded p-3 text-center text-neutral-dark hover:border-brand-primary hover:text-brand-primary no-underline transition-colors">Mental health</a>
      <a href="https://www.nhsinform.scot/healthy-living/screening/" rel="noopener noreferrer" class="text-sm bg-white border border-gray-200 rounded p-3 text-center text-neutral-dark hover:border-brand-primary hover:text-brand-primary no-underline transition-colors">Screening</a>
      <a href="https://www.nhsinform.scot/campaigns/managing-your-long-term-condition/" rel="noopener noreferrer" class="text-sm bg-white border border-gray-200 rounded p-3 text-center text-neutral-dark hover:border-brand-primary hover:text-brand-primary no-underline transition-colors">Long-term conditions</a>
      <a href="https://www.nhsinform.scot/translations/" rel="noopener noreferrer" class="text-sm bg-white border border-gray-200 rounded p-3 text-center text-neutral-dark hover:border-brand-primary hover:text-brand-primary no-underline transition-colors">Other languages</a>
    </div>
  </div>
</section>
